# Telegram Bot API credentials and message source
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_REPOSITORY=owner/repository
TELEGRAM_ALLOWED_BRANCHES=main
# Optional forum-topic filter
# TELEGRAM_TOPIC_ID=123

# Deployment target
TARGET_FOLDER=/srv/my-compose-project
COMPOSE_PROFILES=production
# Optional Compose configuration
# COMPOSE_FILE=docker-compose.yml
# COMPOSE_SERVICES=web api

# Optional polling and logging configuration
TELEGRAM_POLL_TIMEOUT=30
TELEGRAM_HTTP_TIMEOUT=40
# Minimum spacing between successive getUpdates requests, including backlog processing.
TELEGRAM_MIN_POLL_INTERVAL_SECONDS=0.5
# Delay before retrying a deployment update that failed locally.
TELEGRAM_FAILURE_RETRY_SECONDS=30
LOG_LEVEL=INFO
# Optional custom gate regex. The parser still validates Branch, Commit, and Details.
# TELEGRAM_MESSAGE_REGEX=(?ims)^New commit on
